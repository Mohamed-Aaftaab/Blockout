# ─── Credentials ─────────────────────────────────────────────────────────────
# CoinMarketCap Pro API key (required, min 32 chars)
CMC_API_KEY=your_cmc_pro_api_key_here_32_chars_min

# Trust Wallet Agent Kit credentials (optional — reserved for when TWAK SDK publishes)
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=

# ─── Network ─────────────────────────────────────────────────────────────────
# Network mode: testnet | mainnet (default: testnet)
NETWORK_MODE=testnet

# BSC RPC endpoints (required, comma-separated, ordered by priority)
RPC_ENDPOINTS=https://bsc-dataseed1.binance.org,https://bsc-dataseed2.binance.org,https://bsc-dataseed3.binance.org

# Chain ID: 56=mainnet, 97=testnet (required)
CHAIN_ID=97

# ─── Trading Pairs ────────────────────────────────────────────────────────────
# Comma-separated pairs in UPPER/UPPER format (required, min 1)
TRADING_PAIRS=BNB/USDT,CAKE/USDT

# ─── Venue Contracts ─────────────────────────────────────────────────────────
# PancakeSwap V2 Router address (required)
# Mainnet:  0x10ED43C718714eb63d5aA57B78B54704E256024E
# Testnet:  0xD99D1c33F9fC3444f8101754aBC46c52416550D1
PANCAKESWAP_ROUTER=0x10ED43C718714eb63d5aA57B78B54704E256024E

# BSC Perpetuals contract address (required — set to zero address if unused)
BSC_PERPS_CONTRACT=0x0000000000000000000000000000000000000000

# ─── Risk Management ─────────────────────────────────────────────────────────
# Max portfolio % per position (0.1–20, default: 5)
MAX_POSITION_PCT=5

# Max total portfolio exposure % (1–100, default: 30)
MAX_EXPOSURE_PCT=30

# Stop-loss % below entry for buys / above entry for sells (0.1–50, default: 5)
STOP_LOSS_PCT=5

# Take-profit % above entry for buys / below entry for sells (0.1–200, default: 15)
TAKE_PROFIT_PCT=15

# Max drawdown % before circuit breaker activates (1–50, default: 20)
MAX_DRAWDOWN_PCT=20

# Min portfolio value USD to allow new trades (>=10, default: 100)
MIN_PORTFOLIO_USD=100

# Leverage multiplier for BSC Perps (1–20, default: 1)
LEVERAGE_MULTIPLIER=1

# ─── TWAP / MEV Defense (Anaconda Squeeze) ────────────────────────────────────
# Order size USD threshold above which TWAP splits are used (>=1, default: 50)
TWAP_THRESHOLD_USD=1000

# Number of TWAP chunks (2–20, default: 10)
TWAP_CHUNK_COUNT=10

# Min delay between TWAP chunks ms (5000–60000, default: 15000)
TWAP_MIN_INTERVAL_MS=15000

# Max delay between TWAP chunks ms (5000–300000, default: 45000)
TWAP_MAX_INTERVAL_MS=45000

# ─── Gas Optimization ─────────────────────────────────────────────────────────
# Gas urgency multiplier (1.0–3.0, default: 1.2)
GAS_URGENCY_MULTIPLIER=1.2

# Minimum gas price Gwei (1–100, default: 3)
MIN_GAS_GWEI=3

# Maximum gas price Gwei (1–1000, default: 100)
MAX_GAS_GWEI=100

# ─── Slippage ─────────────────────────────────────────────────────────────────
# Default slippage tolerance % (0.1–5, default: 0.5)
DEFAULT_SLIPPAGE_PCT=0.5

# Maximum allowed slippage % (0.5–10, default: 3.0)
MAX_SLIPPAGE_PCT=3.0

# ─── Signals ──────────────────────────────────────────────────────────────────
# RSI oversold threshold for buy signal (10–40, default: 30)
RSI_OVERSOLD=30

# RSI overbought threshold for sell signal (60–90, default: 70)
RSI_OVERBOUGHT=70

# ─── Scalping Strategy ────────────────────────────────────────────────────────
# ATH dip % to trigger mid-battle scalping entry (10–80, default: 35)
SCALPING_ATH_DROP_PCT=35

# Scalping take-profit % above entry (0.1–100, default: 15)
SCALPING_TP_PCT=15

# ─── Pool Health (Dead-Coin Filter) ───────────────────────────────────────────
# Min pool reserve USD (>=1000, default: 50000)
MIN_POOL_RESERVE_USD=50000

# Min estimated 24h volume to reserve ratio % (0.1–100, default: 5)
# Note: on-chain volume is estimated as ~4% of reserve; setting above 4% rejects thin pools.
MIN_VOL_TO_RESERVE_PCT=5

# Min estimated 24h transaction count (>=1, default: 100)
MIN_TX_COUNT_24H=100

# ─── Timing & Intervals ───────────────────────────────────────────────────────
# Market data refresh interval seconds (10–3600, default: 60)
DATA_REFRESH_SEC=60

# SL/TP monitor interval ms (1000–60000, default: 10000)
SL_MONITOR_MS=10000

# Drawdown check interval seconds (10–3600, default: 60)
DRAWDOWN_CHECK_SEC=60

# Trading hours UTC start HH:MM (default: 00:00 = all day)
TRADING_HOURS_START=00:00

# Trading hours UTC end HH:MM (default: 23:59 = all day)
TRADING_HOURS_END=23:59

# ─── Performance & Latency ────────────────────────────────────────────────────
# Metrics calculation interval seconds (60–3600, default: 300)
METRICS_CALC_SEC=300

# Latency warning threshold ms — emits health:latency event (1000–30000, default: 5000)
LATENCY_WARNING_MS=5000

# Latency target ms — logs warn when exceeded (100–10000, default: 3000)
LATENCY_TARGET_MS=3000

# Transaction confirmation timeout seconds (30–600, default: 120)
TX_TIMEOUT_SEC=120

# ─── State & Persistence ──────────────────────────────────────────────────────
# State file path (default: ./data/state.json)
STATE_FILE_PATH=./data/state.json

# Periodic state save interval seconds (1–300, default: 30)
STATE_PERSIST_SEC=30

# Analytics file path (default: ./data/analytics.json)
ANALYTICS_FILE_PATH=./data/analytics.json

# ─── Operations ───────────────────────────────────────────────────────────────
# Emergency shutdown signal file — touch this file to trigger graceful shutdown
SHUTDOWN_SIGNAL_FILE=./SHUTDOWN

# Shutdown signal poll interval ms (1000–30000, default: 5000)
SHUTDOWN_POLL_MS=5000

# Log level: debug | info | warn | error | critical (default: info)
# Set LOG_LEVEL=debug for verbose output during development
LOG_LEVEL=info

# ─── Adaptive Strategy Weights ────────────────────────────────────────────────
# Enable adaptive weight adjustment (default: false)
ADAPTIVE_ENABLED=false

# ─── Demo / Backtest Mode ─────────────────────────────────────────────────────
# Demo mode — runs without live execution (default: false)
DEMO_MODE=false

# Demo duration seconds (default: 3600)
DEMO_DURATION=3600

# Demo starting capital USD (default: 1000)
DEMO_CAPITAL=1000

# Backtest mode (default: false)
BACKTEST_MODE=false

# Backtest date range ISO format (optional)
BACKTEST_FROM=
BACKTEST_TO=

# Backtest starting capital USD (default: 10000)
BACKTEST_CAPITAL=10000
